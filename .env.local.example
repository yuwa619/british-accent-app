# Local beta QA environment template.
# Copy this file to .env.local and fill values from your staging providers.
# Never commit .env.local or real API keys.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI provider testing
ENABLE_REAL_AI=false
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
OPENAI_API_KEY=

# Reference and roleplay audio
ENABLE_ELEVENLABS=false
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Stripe remains disabled for MVP beta unless explicitly approved for test mode.
ENABLE_STRIPE_CHECKOUT=false
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Analytics and monitoring are disabled until privacy QA passes.
ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_ANALYTICS=false
POSTHOG_KEY=
POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
ENABLE_SENTRY=false
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Optional email/reminders
RESEND_API_KEY=

# Protected maintenance and system-health checks.
MAINTENANCE_SECRET=

# Optional Vercel Deployment Protection bypass for preview Playwright tests.
VERCEL_AUTOMATION_BYPASS_SECRET=
